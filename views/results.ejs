<!DOCTYPE html>
<html lang="cs">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    :root {
      --bg: #f5f7fa;
      --panel: #ffffff;
      --border: #dbe2ea;
      --text: #1e293b;
      --accent: #0f766e;
      --muted: #64748b;
    }

    body {
      margin: 0;
      font-family: "Source Sans 3", sans-serif;
      color: var(--text);
      background: var(--bg);
    }

    .page-shell {
      max-width: 980px;
      margin: 0 auto;
      padding: 20px 14px;
    }

    .hero {
      margin-bottom: 10px;
      padding: 12px 14px;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--panel);
    }

    .hero h1 {
      margin: 0 0 4px;
      font-weight: 700;
      font-size: clamp(1.6rem, 4vw, 2.1rem);
    }

    .hero p {
      margin: 2px 0 8px;
      color: var(--muted);
      line-height: 1.5;
    }

    .hero-pill {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      border: 1px solid #bbf7d0;
      background: #ecfdf5;
      color: var(--muted);
      font-size: 0.9rem;
    }

    .results-grid {
      display: grid;
      gap: 8px;
    }

    .response-card {
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--panel);
      padding: 10px;
      display: grid;
      grid-auto-flow: row;
      gap: 6px;
    }

    .response-card strong {
      color: var(--text);
      font-weight: 700;
      font-size: 0.95rem;
    }

    .response-card .muted {
      color: var(--muted);
      font-size: 0.85rem;
    }

    .field-row {
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 8px 10px;
      background: #fcfdff;
    }

    .field-label {
      display: block;
      margin-bottom: 3px;
      font-weight: 600;
      color: #334155;
      font-size: 0.9rem;
    }

    .value-text {
      color: var(--text);
      line-height: 1.4;
      word-break: break-word;
      font-size: 0.95rem;
    }

    .btn-back {
      background: var(--accent);
      border: none;
      border-radius: 8px;
      font-weight: 700;
      padding: 0.6rem 0.95rem;
    }

    .btn-back:hover {
      background: #0b5f59;
    }

    @media (max-width: 576px) {
      .page-shell {
        padding: 14px 10px;
      }

      .hero {
        padding: 10px;
      }

      .response-card {
        padding: 8px;
      }
    }
  </style>
</head>

<body>

  <main class="page-shell">
    <!-- Hlavicka stranky se souhrnem poctu zaznamu. -->
    <section class="hero">
      <h1><%= title %></h1>
      <p>Přehled všech odpovědí v jednoduchém a přehledném rozložení.</p>
      <span class="hero-pill"><strong><%= responses.length %></strong> záznamů</span>
    </section>

    <!-- Fallback pri prazdnem seznamu odpovedi. -->
    <% if (responses.length === 0) { %>
      <div class="hero text-center">
        <p class="mb-0">Zatím nejsou žádné odpovědi.</p>
      </div>
    <% } %>

    <!-- Vypis jednotlivych odpovedi z responses.json. -->
    <section class="results-grid">
      <% responses.forEach(r => { %>
        <article class="response-card">
          <strong>ID <%= r.id %></strong>
          <span class="muted">Odesláno: <%= r.timestamp %></span>
          <div class="field-row">
            <div class="field-label">Oblíbený den</div>
            <div class="value-text"><%= r.answers.den || r.answers.predmet %></div>
          </div>
          <div class="field-row">
            <div class="field-label">Pohyb</div>
            <div class="value-text"><%= r.answers.sport || r.answers.hodiny %></div>
          </div>
          <div class="field-row">
            <div class="field-label">Volný čas</div>
            <div class="value-text"><%= r.answers.volnycas || r.answers.uceni %></div>
          </div>
          <div class="field-row">
            <div class="field-label">Komentář</div>
            <div class="value-text"><%= r.answers.komentar || r.answers.zlepseni %></div>
          </div>
        </article>
      <% }) %>
    </section>

    <!-- Navigace zpet na vstupni formular. -->
    <div style="text-align: center; margin-top: 12px;">
      <a href="/" class="btn btn-back px-4">Zpět na formulář</a>
    </div>

  </main>

</body>

</html>
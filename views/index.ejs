<!DOCTYPE html>
<html lang="cs">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>
    <%= title %>
  </title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    :root {
      --bg: #f5f7fa;
      --panel: #ffffff;
      --border: #dbe2ea;
      --text: #1e293b;
      --accent: #0f766e;
      --muted: #64748b;
    }

    body {
      margin: 0;
      font-family: "Source Sans 3", sans-serif;
      color: var(--text);
      background: var(--bg);
    }

    .page-shell {
      max-width: 760px;
      margin: 0 auto;
      padding: 20px 14px;
    }

    .hero-badge {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      background: #ecfdf5;
      border: 1px solid #bbf7d0;
      color: var(--muted);
      font-size: 0.85rem;
      margin-bottom: 10px;
    }

    .form-card {
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--panel);
      padding: 18px;
    }

    .form-head {
      margin-bottom: 14px;
    }

    .form-head h1 {
      margin: 0;
      font-size: clamp(1.6rem, 4vw, 2.1rem);
      font-weight: 700;
    }

    .form-head p {
      margin: 6px 0 0;
      color: var(--muted);
      line-height: 1.5;
    }

    .question-grid {
      display: grid;
      gap: 10px;
    }

    .question-block {
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px;
      background: #fcfdff;
    }

    .form-label {
      margin-bottom: 6px;
      font-weight: 600;
    }

    .form-select,
    .form-control {
      border: 1px solid #cbd5e1;
      border-radius: 8px;
    }

    .form-select:focus,
    .form-control:focus {
      border-color: #14b8a6;
      box-shadow: 0 0 0 2px rgba(20, 184, 166, 0.18);
    }

    .form-select option {
      color: #0f172a;
    }

    .submit-row {
      margin-top: 4px;
    }

    .btn-primary {
      background: var(--accent);
      border: none;
      border-radius: 8px;
      font-weight: 700;
      padding: 0.65rem 0.95rem;
    }

    .btn-primary:hover {
      background: #0b5f59;
    }

    @media (max-width: 576px) {
      .page-shell {
        padding: 14px 10px;
      }

      .form-card {
        padding: 14px;
      }
    }
  </style>
</head>

<body>

  <main class="page-shell">
    <!-- Hlavni karta s formularem ankety. -->
    <section class="form-card">
      <div class="form-head text-center text-sm-start">
        <div class="hero-badge"><span></span> Rychlá anonymní anketa</div>
        <h1><%= title %></h1>
        <p>Vyplň krátký formulář a po odeslání se odpovědi zobrazí v přehledu výsledků.</p>
      </div>

      <!-- Otazky formulare odesilane na /submit. -->
      <form action="/submit" method="POST" class="question-grid">
        <div class="question-block">
          <label class="form-label">Oblíbený den v týdnu</label>

          <select class="form-select" name="den" required>
            <option value="">Vyber...</option>
            <option value="Pondělí">Pondělí</option>
            <option value="Úterý">Úterý</option>
            <option value="Středa">Středa</option>
            <option value="Čtvrtek">Čtvrtek</option>
            <option value="Pátek">Pátek</option>
            <option value="Sobota">Sobota</option>
            <option value="Neděle">Neděle</option>
          </select>
        </div>


        <div class="question-block">
          <label class="form-label">Jak často sportuješ během týdne?</label>

          <select class="form-select" name="sport" required>
            <option value="">Vyber...</option>
            <option value="nikdy">Nikdy</option>
            <option value="1-2x">1–2x týdně</option>
            <option value="3-4x">3–4x týdně</option>
            <option value="5+x">5x a více týdně</option>
          </select>
        </div>


        <div class="question-block">
          <label class="form-label">Jak nejraději trávíš volný čas?</label>

          <select class="form-select" name="volnycas" required>
            <option value="">Vyber...</option>
            <option value="sport">Sportem</option>
            <option value="knihy">Čtením knih</option>
            <option value="pc">Na počítači</option>
            <option value="rodina">S rodinou nebo přáteli</option>
          </select>
        </div>


        <div class="question-block">
          <label class="form-label">Komentář:</label>

          <textarea class="form-control" name="komentar" rows="3" required></textarea>
        </div>

        <!-- Primarni akce pro ulozeni odpovedi. -->
        <div class="submit-row">
          <button class="btn btn-primary w-100">
          Odeslat zprávu
          </button>
        </div>
      </form>

    </section>
  </main>

</body>

</html>